# ── LLM Configuration ──
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Application ──
APP_ENV=development
LOG_LEVEL=INFO

# ── Session ──
SESSION_TTL_SECONDS=3600

# ── Security ──
# Comma-separated list of valid API keys
API_KEYS=test-key,another-key

# ── Rate Limiting ──
RATE_LIMIT=60/minute

# ── Database ──
# Aiven MySQL connection string.
# Format: mysql+pymysql://<user>:<password>@<host>:<port>/<dbname>?ssl_disabled=False
# Aiven enforces TLS — keep ssl_disabled=False at all times.
DATABASE_URL=mysql+pymysql://user:password@host:port/dbname?ssl_disabled=False

# Optional: absolute path to the Aiven CA certificate for full chain verification.
# Leave empty to use system / platform trust-store validation.
DB_SSL_CA=
