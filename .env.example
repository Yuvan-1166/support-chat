# ── LLM Configuration ──
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Application ──
APP_ENV=development
LOG_LEVEL=INFO

# ── Session ──
SESSION_TTL_SECONDS=3600

# ── Security ──
# Comma-separated list of valid API keys
API_KEYS=test-key,another-key

# ── Rate Limiting ──
RATE_LIMIT=60/minute

# ── Database ──
# Aiven MySQL connection string.
# Format: mysql+pymysql://<user>:<password>@<host>:<port>/<dbname>?ssl_disabled=False
# Aiven enforces TLS — keep ssl_disabled=False at all times.
DATABASE_URL=mysql+pymysql://user:password@host:port/dbname?ssl_disabled=False

# Optional: absolute path to the Aiven CA certificate for full chain verification.
# Use this for LOCAL DEVELOPMENT where ca.pem is on disk.
DB_SSL_CA=ca.pem

# Optional: base64-encoded content of the Aiven CA certificate.
# Use this for CLOUD / CONTAINER deployments (Render, Railway, Fly.io, etc.)
# where you cannot mount files. Generate the value with:
#   base64 -w0 ca.pem
# Then paste the output as this env var in your hosting dashboard.
# This takes precedence over DB_SSL_CA when both are set.
DB_SSL_CA_B64=
